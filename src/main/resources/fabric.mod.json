{
  "schemaVersion": 1,
  "id": "noendflash",
  "version": "${version}",
  "name": "No End Flash",
  "description": "Simple mod for delete End Flash (purple lightning in any time)",
  "authors": [
    "y9lihop"
  ],
  "issues": [
	"https://github.com/y9dev/No-End-Flash/issues"
  ],
  "sources": [
	"https://github.com/y9dev/No-End-Flash"
  ],
  "contact": {},
  "license": "CC0-1.0",
  "icon": "assets/noendflash/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "net.y9.noendflash.NoEndFlashClient"
    ],
    "main": [
      "net.y9.noendflash.NoEndFlash"
    ]
  },
  "mixins": [
    "no-end-flash.mixins.json",
    {
      "config": "no-end-flash.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.18.4",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
